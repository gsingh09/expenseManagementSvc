{
  "apps": [
    {
      "name": "expenseManagementSvc",
      "script": "src/application/index.js",
      "instances": 4,
      "exec_mode": "cluster",
      "watch": false,
      "ignore_watch": ["node_modules", "logs", "temp"],
      "watch_delay": 60000,
      "merge_logs": true,
      "error_file": "./logs/pm2-error.log",
      "out_file": "./logs/pm2-out.log",
      "log_file": "./logs/pm2-combined.log",
      "time": true,
      "env": {
        "NODE_ENV": "production",
        "CONFIG_FILE": "./config/expense-management-svc/production",
        "LOG_DIR": "./logs/production",
        "LOG_LEVEL": "warn"
      },
      "restart_delay": 4000,
      "max_memory_restart": "500M"
    }
  ]
}
