{
  "apps": [
    {
      "name": "expenseManagementSvc",
      "script": "index.js",
      "instances": 4,
      "exec_mode": "cluster",
      "watch": false,
      "ignore_watch": ["node_modules", "logs", "temp"],
      "watch_delay": 60000,
      "time": true,
      "env": {
        "NODE_ENV": "production",
        "CONFIG_FILE": "./config/expense-management-svc/production",
        "LOG_DIR": "/usr/local/logs",
        "LOG_LEVEL": "debug"
      },
      "restart_delay": 4000,
      "max_memory_restart": "500M"
    }
  ]
}
