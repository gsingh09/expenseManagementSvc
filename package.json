{
  "name": "expense-management-svc",
  "version": "1.0.0",
  "description": "Scalable expense management platform with configurable approval workflows",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "dotenv -e config/expense-management-svc/local/application.env nodemon src/index.js",
    "test": "dotenv -e config/expense-management-svc/test/application.env jest --detectOpenHandles --forceExit",
    "test:watch": "dotenv -e config/expense-management-svc/test/application.env jest --watch",
    "test:coverage": "dotenv -e config/expense-management-svc/test/application.env jest --coverage"
  },
  "keywords": [
    "expense",
    "management",
    "approval",
    "workflow"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.0.0",
    "joi": "^17.10.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.6.0",
    "sequelize": "^6.35.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.3.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "sequelize-mock": "^0.10.2",
    "supertest": "^6.3.3"
  }
}
